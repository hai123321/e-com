# Database
DB_USER=miushop
DB_PASSWORD=your_db_password_here

# Backend
JWT_SECRET=your_jwt_secret_here_min_32_chars
CORS_ORIGIN=https://miushop.io.vn
ADMIN_PASSWORD=your_admin_password_here

# Frontend
NEXT_PUBLIC_API_URL=https://api.miushop.io.vn
# Internal Docker network — không cần đổi
API_INTERNAL_URL=http://api:3001

# Sepay Payment Gateway (optional — falls back to VietQR if not set)
SEPAY_MERCHANT_ID=your_sepay_merchant_id
SEPAY_SECRET_KEY=your_sepay_secret_key
SEPAY_API_URL=https://my.sepay.vn/userapi
